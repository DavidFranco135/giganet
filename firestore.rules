rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra geral do usuário: requer login não anônimo
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    // Regras específicas para o provedor (ISP)
    match /users/{userId} {
      allow read: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin';
    }
    
    match /invoices/{invoiceId} {
      allow read: if request.auth.uid == resource.data.userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin';
    }

    // Regras adicionais fornecidas pelo usuário
    match /services/{serviceId} {
      allow read, update: if request.auth != null;
    }
    match /trips/{tripId} {
      allow create: if request.auth != null;
    }
  }
}
