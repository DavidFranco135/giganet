// firestore.rules — Multi-tenant GigaNet
// Cole no Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Cada provedor é isolado ──────────────────────────────────
    match /provedores/{provedorId} {

      // Settings/profile — leitura pública (logo, capa, bg login)
      // Escrita apenas pelo admin do provedor
      match /settings/profile {
        allow read:  if true;
        allow write: if isAdminOf(provedorId);
      }

      // Users — cada cliente lê/escreve apenas seus próprios dados
      // Admin do provedor lê todos
      match /users/{userId} {
        allow read:  if request.auth.uid == userId
                     || isAdminOf(provedorId);
        allow create: if request.auth.uid == userId;
        allow update: if request.auth.uid == userId
                     || isAdminOf(provedorId);
        allow delete: if isAdminOf(provedorId);
      }

      // Anúncios — leitura pública, escrita apenas admin
      match /announcements/{docId} {
        allow read:  if request.auth != null;
        allow write: if isAdminOf(provedorId);
      }

      // Dispositivos — leitura pública, escrita apenas admin
      match /deviceImages/{docId} {
        allow read:  if request.auth != null;
        allow write: if isAdminOf(provedorId);
      }

      // Planos — leitura pública, escrita apenas admin
      match /plans/{docId} {
        allow read:  if true;
        allow write: if isAdminOf(provedorId);
      }

      // Chamados — cliente lê/cria os seus, admin lê todos
      match /tickets/{docId} {
        allow read:  if resource.data.uid == request.auth.uid
                     || isAdminOf(provedorId);
        allow create: if request.auth != null;
        allow update: if isAdminOf(provedorId);
        allow delete: if isAdminOf(provedorId);
      }
    }

    // ── Função: verifica se o usuário é admin do provedor ────────
    function isAdminOf(provedorId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/provedores/$(provedorId)/users/$(request.auth.uid)).data.tipo == 'admin';
    }
  }
}
