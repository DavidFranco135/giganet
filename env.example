# ─────────────────────────────────────────────
#  .env.local — GigaNet App
#  Copie este arquivo para .env.local e preencha
# ─────────────────────────────────────────────

# Gemini AI (Google)
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── IXC Soft ─────────────────────────────────
# URL do seu servidor IXC (sem barra no final)
IXC_URL=https://ixc.suaempresa.com.br

# Token gerado no IXC: Configurações > Usuários > [usuário da integração] > Token de acesso
IXC_TOKEN=seu_token_ixc_aqui

# ── Firebase Admin (opcional em produção) ────
# Se tiver o arquivo serviceAccountKey.json, cole o conteúdo aqui
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
